{
  "$schema": "https://turbo.build/schema.json",

  "tasks": {
    "dev": {
      "persistent": true,

      "cache": false
    },

    "build": {
      "dependsOn": ["^build"],

      "outputs": ["dist/**"]
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "typecheck": {
      "dependsOn": ["^typecheck"]
    },

    "clean": {
      "cache": false
    }
  }
}
