{
  "compilerOptions": {
    "target": "ES2023",

    "lib": ["ES2023"],

    "module": "ESNext",

    "moduleResolution": "Bundler",

    "strict": true,

    "declaration": true,

    "declarationMap": true,

    "sourceMap": true,

    "resolveJsonModule": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "exactOptionalPropertyTypes": true,

    "noUncheckedIndexedAccess": true,

    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",

    "paths": {
      "@signala/shared": ["packages/shared/src/index.ts"],

      "@signala/shared/*": ["packages/shared/src/*"],

      "@signala/collector": ["apps/collector/src/index.ts"],

      "@signala/collector/*": ["apps/collector/src/*"],

      "@signala/feature-engine": ["apps/feature-engine/src/index.ts"],

      "@signala/feature-engine/*": ["apps/feature-engine/src/*"],

      "@signala/whale-engine": ["apps/whale-engine/src/index.ts"],

      "@signala/whale-engine/*": ["apps/whale-engine/src/*"],

      "@signala/liquidity-engine": ["apps/liquidity-engine/src/index.ts"],

      "@signala/liquidity-engine/*": ["apps/liquidity-engine/src/*"],

      "@signala/market-state-engine": ["apps/market-state-engine/src/index.ts"],

      "@signala/market-state-engine/*": ["apps/market-state-engine/src/*"],

      "@signala/signal-engine": ["apps/signal-engine/src/index.ts"],

      "@signala/signal-engine/*": ["apps/signal-engine/src/*"]
    }
  }
}
